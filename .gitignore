# Dependencies (unanchored, catches node_modules at any depth, root or nested apps/*)
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Environment files, never commit secrets
.env
.env*.local

# Next.js
/.next/
/out/

# Build outputs (unanchored, catches dist/ in socket-server, lambdas, etc too)
dist/
build/
*.tsbuildinfo
next-env.d.ts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# Vercel (unused here, but harmless to keep)
.vercel

# AWS / infra local state
infra/**/*.pem
infra/**/.terraform/

dynamodb-data/