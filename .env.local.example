# Copy this file to .env.local and fill in real values.
# .env.local is gitignored, never commit real secrets.

# DeepSeek API (used starting Phase 4, safe to leave blank until then)
DEEPSEEK_API_KEY=

# NextAuth (used starting Phase 6)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Socket.IO server URL (points at EC2 once Phase 2 is deployed, localhost until then)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000